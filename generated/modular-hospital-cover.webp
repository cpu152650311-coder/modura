<!-- ===== HERO ===== -->
<section class="hero">
  <div class="container">
  <div class="hero-grid">
    <div class="hero-content" data-reveal>
      <span class="hero-eyebrow">Modular Construction</span>
      <h1 class="hero-title">Build Better.<br>Build Faster.</h1>
      <p class="hero-subtitle">We design and manufacture precision-engineered modular buildings — apartments, hotels, and offices — delivered 50% faster than conventional construction, with uncompromising quality.</p>
      <div class="hero-actions">
        <a href="contact.html" class="btn btn-primary">Start Your Project</a>
        <a href="process.html" class="btn btn-ghost">See How It Works</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num" data-counter="500" data-suffix="+">0</span>
          <span class="hero-stat-label">Projects Delivered</span>
        </div>
        <div class="hero-stat">
          <span class="hero-stat-num" data-counter="18" data-suffix="">0</span>
          <span class="hero-stat-label">Countries Served</span>
        </div>
      </div>
    </div>
    <div class="hero-image" data-reveal>
      <img src="generated/hero-modular-construction.webp" alt="Crane lowering a finished modular building unit onto a multi-story building frame at a construction site" loading="eager">
    </div>
  </div>
  </div>
</section>

<!-- ===== VALUE PROPS ===== -->
<section class="section section-alt">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-eyebrow">Why Modular</span>
      <h2 class="section-title">The Modular Advantage</h2>
      <p class="section-desc">Modular construction moves 80% of building work into a controlled factory environment. The result: faster delivery, higher quality, less waste, and lower total cost.</p>
    </div>
    <div class="feature-grid">
      <div class="feature-card" data-reveal>
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>50% Faster Delivery</h3>
        <p>Site preparation and factory production happen simultaneously. A 100-unit apartment building completes in 8 months, not 18.</p>
      </div>
      <div class="feature-card" data-reveal>
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        </div>
        <h3>Factory-Controlled Quality</h3>
        <p>Every module is built to exact specifications with laser-guided precision. ISO 9001 quality management at every workstation.</p>
      </div>
      <div class="feature-card" data-reveal>
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        </div>
        <h3>Sustainable by Design</h3>
        <p>70% less construction waste, 30% lower carbon footprint, and energy-efficient envelopes that reduce operating costs for decades.</p>
      </div>
      <div class="feature-card" data-reveal>
        <div class="feature-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 1v22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <h3>Lower Total Cost</h3>
        <p>Reduced labor, shorter financing periods, and predictable budgets. Modular delivers 15-20% total project cost savings on average.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== PRODUCTS ===== -->
<section class="section">
  <div class="container">
    <div class="section-header" data-reveal>
      <span class="section-eyebrow">Our Products</span>
      <h2 class="section-title">Built for Every Sector</h2>
      <p class="section-desc">From multi-family residential to hospitality and commercial, we engineer modular solutions for diverse building types.</p>
    </div>
    <div class="product-grid">
      <a href="apartments.html" class="product-card" data-reveal>
        <div class="product-card-img">
          <img src="generated/apartment-exterior.webp" alt="Modern 5-story modular apartment building with clean facade and balconies" loading="lazy">
        </div>
        <div class="product-card-body">
          <h3>Modular Apartments</h3>
          <p>Multi-family residential, student housing, and workforce housing. 20-200 units, delivered move-in ready.</p>
          <span class="product-card-link">Explore Apartments →</span>
        </div>
      </a>
      <a href="hotels.html" class="product-card" data-reveal>
        <div class="product-card-img">
          <img src="generated/hotel-exterior.webp" alt="Modern 6-story modular hotel building with sleek facade at dusk" loading="lazy">
        </div>
        <div class="product-card-body">
          <h3>Modular Hotels</h3>
          <p>Hotel chains, resorts, and extended-stay properties. Speed-to-market without compromising brand standards.</p>
          <span class="product-card-link">Explore Hotels →</span>
        </div>
      </a>
      <a href="offices.html" class="product-card" data-reveal>
        <div class="product-card-img">
          <img src="generated/office-exterior.webp" alt="Contemporary 3-story modular office building with glass curtain wall" loading="lazy">
        </div>
        <div class="product-card-body">
          <h3>Modular Offices</h3>
          <p>Commercial offices, co-working spaces, and government buildings. Scalable, relocatable, and disruption-free.</p>
          <span class="product-card-link">Explore Offices →</span>
        </div>
      </a>
    </div>
  </div>
</section>

